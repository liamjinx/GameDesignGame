  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: 'Butler: States a character is lying. Will always select ghosts if lying,
    or ghosts if telling the truth


    Doctor: States an honest subject, lying
    subject and a ghost. If lying, will call a ghost a lying subject and a lying
    subject a ghost


    Alchemist: States if they are next to at least one lying
    subject. Could be one ghost and one subject, or two subjects


    Troubadour:
    States two potential subjects that could be lying. One or both of the subjects
    could be lying. If lying, will choose one more more ghosts, and will never pick
    lying subjects


    ALL GHOSTS: Disguises as a random subject and gives false
    information


    Phantom: A subject next to me lies


    Nuckelavee: Subjects
    next to me lie'
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 241c6acceca8b844baad6cbcf60cefc7, type: 2}
