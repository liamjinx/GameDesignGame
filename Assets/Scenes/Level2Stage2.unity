--- !u!1001 &1843465756
PrefabInstance:
  m_ObjectHideFlags: 0
  serializedVersion: 2
  m_Modification:
    serializedVersion: 3
    m_TransformParent: {fileID: 0}
    m_Modifications:
    - target: {fileID: 564308043685198918, guid: 07a58fb99198d8f429d06902a541622e, type: 3}
      propertyPath: m_text
      value: 'Queen: States if they are next to at least one ghost. Could be one
        ghost and one subject, or two subjects


        Jester: Either the Jester
        or another subject is the ghost. If the chosen subject isn''t the ghost,
        then the Jester is lying


        Maid: States a character is a ghost. Will
        always select subjects if lying, or ghosts if telling the truth


        Bard:
        States how far away they are from the closest ghost. If lying, states how
        far away they are from the closest subject'
      objectReference: {fileID: 0}
    - target: {fileID: 649765280201625091, guid: 07a58fb99198d8f429d06902a541622e, type: 3}
      propertyPath: m_text
      value: 'Butler: States a character is lying. Will always select ghosts if lying,
        or ghosts if telling the truth


        Blacksmith: States how far away
        they are from the closest lying subject. If lying, states how far away they
        are from the closest ghost


        Alchemist: States if they are next to
        at least one lying subject. Could be one ghost and one subject, or two subjects


        ALL
        GHOSTS: Disguises as a random subject and gives false information


        Nuckelavee:
        Subjects next to me lie'
      objectReference: {fileID: 0}
    - target: {fileID: 7178253644178797337, guid: 07a58fb99198d8f429d06902a541622e, type: 3}
      propertyPath: m_PresetInfoIsWorld
      value: 1
      objectReference: {fileID: 0}
