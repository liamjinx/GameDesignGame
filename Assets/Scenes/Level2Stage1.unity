--- !u!1001 &456263486
PrefabInstance:
  m_ObjectHideFlags: 0
  serializedVersion: 2
  m_Modification:
    serializedVersion: 3
    m_TransformParent: {fileID: 0}
    m_Modifications:
    - target: {fileID: 321053737242813839, guid: 07a58fb99198d8f429d06902a541622e, type: 3}
      propertyPath: m_IsActive
      value: 1
      objectReference: {fileID: 0}
    - target: {fileID: 564308043685198918, guid: 07a58fb99198d8f429d06902a541622e, type: 3}
      propertyPath: m_text
      value: 'King: States if they are next to at least one safe character. Could
        be one ghost and one subject, or two subjects


        Jester: Either the
        Jester or another subject is the ghost. If the chosen subject isn''t the
        ghost, then the Jester is lying


        Manservant: States a character
        is a subject. Will always select ghosts if lying, or subjects if telling
        the truth


        Priest: Only one of three characters is a ghost. If lying,
        none of them are '
      objectReference: {fileID: 0}
    - target: {fileID: 649765280201625091, guid: 07a58fb99198d8f429d06902a541622e, type: 3}
      propertyPath: m_text
      value: 'Blacksmith: States how far away they are from the closest lying subject.
        If lying, states how far away they are from the closest ghost


        Chef:
        States a character is telling the truth. Will always select lying subjects
        if lying, or honest subjects if telling the truth


        ALL GHOSTS: Disguises
        as a random subject and gives false information


        Wraith: A random
        subject lies'
      objectReference: {fileID: 0}
    - target: {fileID: 1782723121172210822, guid: 07a58fb99198d8f429d06902a541622e, type: 3}
      propertyPath: m_fontColor.b
