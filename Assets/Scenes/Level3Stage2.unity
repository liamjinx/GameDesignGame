--- !u!1001 &170895684
PrefabInstance:
  m_ObjectHideFlags: 0
  serializedVersion: 2
  m_Modification:
    serializedVersion: 3
    m_TransformParent: {fileID: 0}
    m_Modifications:
    - target: {fileID: 564308043685198918, guid: 07a58fb99198d8f429d06902a541622e, type: 3}
      propertyPath: m_text
      value: 'King: States if they are next to at least one safe character. Could
        be one ghost and one subject, or two subjects


        Queen: States if
        they are next to at least one ghost. Could be one ghost and one subject,
        or two subjects


        Maid: States a character is a ghost. Will always
        select subjects if lying, or ghosts if telling the truth


        Bard:
        States how far away they are from the closest ghost. If lying, states how
        far away they are from the closest subject


        Nun: States two potential
        subjects the ghost could be. One or both of the subjects could be ghosts.
        If lying, neither will be ghosts


        Executioner: the second character
        is a subject if and only if the first is a subject. If lying, the second
        character is a ghost


        Knight: the second character is a ghost if
        and only if the first is a subject. If lying, the second character is a subject'
      objectReference: {fileID: 0}
    - target: {fileID: 649765280201625091, guid: 07a58fb99198d8f429d06902a541622e, type: 3}
      propertyPath: m_text
      value: 'Doctor: States an honest subject, lying subject and a ghost. If lying,
        will call a ghost a lying subject and a lying subject a ghost


        Alchemist:
        States if they are next to at least one lying subject. Could be one ghost
        and one subject, or two subjects


        ALL GHOSTS: Disguises as a random
        subject and gives false information


        Phantom: A subject next to
        me lies


        Nuckelavee: Subjects next to me lie'
      objectReference: {fileID: 0}
    - target: {fileID: 7178253644178797337, guid: 07a58fb99198d8f429d06902a541622e, type: 3}
      propertyPath: m_PresetInfoIsWorld
      value: 1
      objectReference: {fileID: 0}
