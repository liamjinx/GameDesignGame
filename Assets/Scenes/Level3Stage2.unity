  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: 'King: States if they are next to at least one safe character. Could be
    one ghost and one subject, or two subjects


    Queen: States if they are next
    to at least one ghost. Could be one ghost and one subject, or two subjects


    Maid:
    States a character is a ghost. Will always select subjects if lying, or ghosts
    if telling the truth


    Bard: States how far away they are from the closest
    ghost. If lying, states how far away they are from the closest subject


    Nun:
    States two potential subjects the ghost could be. One or both of the subjects
    could be ghosts. If lying, neither will be ghosts


    Executioner: the second
    character is a subject if and only if the first is a subject. If lying, the second
    character is a ghost


    Knight: the second character is a ghost if and only
    if the first is a subject. If lying, the second character is a subject'
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 241c6acceca8b844baad6cbcf60cefc7, type: 2}
