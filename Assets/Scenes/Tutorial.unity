--- !u!1001 &1593749469
PrefabInstance:
  m_ObjectHideFlags: 0
  serializedVersion: 2
  m_Modification:
    serializedVersion: 3
    m_TransformParent: {fileID: 0}
    m_Modifications:
    - target: {fileID: 564308043685198918, guid: 07a58fb99198d8f429d06902a541622e, type: 3}
      propertyPath: m_text
      value: 'Maid: States if a character is a ghost. Will always select subjects
        if lying, or ghosts if telling the truth


        Nun: States two potential
        subjects the ghost could be. One or both of the subjects could be ghosts.
        If lying, neither will be ghosts


        Jester: Either the Jester or another
        subject is the ghost. If the chosen subject isnt the ghost, then the Jester
        is lying


        Queen: States if they are next to at least one ghost.
        Could be one ghost and one subject, or two subjects'
      objectReference: {fileID: 0}
    - target: {fileID: 564308043685198918, guid: 07a58fb99198d8f429d06902a541622e, type: 3}
      propertyPath: m_HorizontalAlignment
      value: 1
      objectReference: {fileID: 0}
    - target: {fileID: 649765280201625091, guid: 07a58fb99198d8f429d06902a541622e, type: 3}
      propertyPath: m_text
      value: 'Blacksmith: States how far away they are from the closest lying subject.
        If lying, states how far away they are from the closest ghost


        Chef:
        States a character is telling the truth. Will always select lying subjects
        if lying, or honest subjects if telling the truth


        ALL GHOSTS: Disguises
        as a random subject and gives false information


        Wraith: A random
        subject lies'
      objectReference: {fileID: 0}
    - target: {fileID: 2252707102340332701, guid: 07a58fb99198d8f429d06902a541622e, type: 3}
      propertyPath: dialoguept2
