  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: 'Doctor: States an honest subject, lying subject and a ghost. If lying,
    will call a ghost a lying subject and a lying subject a ghost


    Chef: States
    a character is telling the truth. Will always select lying subjects if lying,
    or honest subjects if telling the truth


    Troubadour: States two potential
    subjects that could be lying. One or both of the subjects could be lying. If
    lying, will choose one more more ghosts, and will never pick lying subjects


    ALL
    GHOSTS: Disguises as a random subject and gives false information


    Wraith:
    A random subject lies


    Phantom: A subject next to me lies'
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 241c6acceca8b844baad6cbcf60cefc7, type: 2}
