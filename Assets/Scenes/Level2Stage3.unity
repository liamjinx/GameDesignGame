  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "King: States if they are next to at least one safe character. Could be
    one ghost and one subject, or two subjects\r\n\nMaid: States a character is a
    ghost. Will always select subjects if lying, or ghosts if telling the truth\r\n\nPriest:
    Only one of three characters is a ghost. If lying, none of them are \r\n\nNun:
    States two potential subjects the ghost could be. One or both of the subjects
    could be ghosts. If lying, neither will be ghosts\r\n\nExecutioner: the second
    character is a subject if and only if the first is a subject. If lying, the second
    character is a ghost"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 241c6acceca8b844baad6cbcf60cefc7, type: 2}
  m_sharedMaterial: {fileID: -699112959996641730, guid: 241c6acceca8b844baad6cbcf60cefc7, type: 2}
