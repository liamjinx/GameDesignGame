  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "King: States if they are next to at least one safe character. Could be
    one ghost and one subject, or two subjects\n\nManservant: States if a character
    is a subject. Will always select ghosts if lying, or subjects if telling the
    truth\n\nNun: States two potential subjects the ghost could be. One or both of
    the subjects could be ghosts. If lying, neither will be ghosts\n\nJester: Either
    the Jester or another subject is the ghost. If the chosen subject isnt the ghost,
    then the Jester is lying\n\nQueen: States if they are next to at least one ghost.
    Could be one ghost and one subject, or two subjects\n\nMaid: States if a character
    is a ghost. Will always select subjects if lying, or ghosts if telling the truth\n\nPriest:
    Only one of three characters is a ghost. If lying, none of them are \n\nKnight:
    If the first character is a subject, then the second is a ghost. If lying, are
    the second character is a subject\n "
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 241c6acceca8b844baad6cbcf60cefc7, type: 2}
