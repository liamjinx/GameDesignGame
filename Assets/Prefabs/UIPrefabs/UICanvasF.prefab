  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: 'Doctor: States an honest subject, lying subject and a ghost. If lying,
    will call a ghost a lying subject and a lying subject a ghost


    Blacksmith:
    States how far away they are from the closest lying subject. If lying, states
    how far away they are from the closest ghost


    Alchemist: States if they
    are next to at least one lying subject. Could be one ghost and one subject, or
    two subjects


    Chef: States a character is telling the truth. Will always
    select lying subjects if lying, or honest subjects if telling the truth


    Troubadour:
    States two potential subjects that could be lying. One or both of the subjects
    could be lying. If lying, will choose one more more ghosts, and will never pick
    lying subjects


    ALL GHOSTS: Disguises as a random subject and gives false
    information


    Wraith: A random subject lies


    Phantom: A subject next
    to me lies


    Nuckelavee: Subjects next to me lie'
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 241c6acceca8b844baad6cbcf60cefc7, type: 2}
